# Local/private config goes in the include
[include]
        path = ~/.gitconfig.local
[user]
        name = Ryan Gildea
        email = ryangildea@gmail.com
        signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPl3BvmPDHLgP/b/sKhYaBRE+ZTGzveAa00D4DIwZXPs
[credential]
        helper = osxkeychain
[gpg]
        format = ssh
[gpg "ssh"]
        program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[url "git@github.com:"]
        insteadOf = https://github.com/
[pull]
        rebase = true
[push]
        autoSetupRemote = true
[fetch]
        prune = true
[rebase]
        autoSquash = true
[branch]
        autoSetupRebase = always
[log]
        abbrevCommit = true
        decorate = auto
[status]
        short = true
        branch = true
[alias]
        count = !git shortlog -sn
        force-push = push --force-with-lease
        br = branch
        ci = !cz commit
        co = checkout
        cp = cherry-pick
        fp = force-push
        rb = rebase
        st = status
        unstage = reset --quiet HEAD
        uncommit = reset --mixed HEAD~
        ahead = log origin/main..HEAD --oneline --stat
[apply]
        whitespace = nowarn
[color]
        ui = true
[commit]
        gpgsign = true
        template = ~/.gitmessage
[core]
        excludesfile = ~/.gitignore
        hooksPath = ~/.git-hooks
        editor = code
        pager = delta
        whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
[diff]
        colorMoved = default
[difftool]
        prompt = false
        trustExitCode = true
[interactive]
        diffFilter = delta --color-only
[delta]
        navigate = true
        light = false
        line-numbers = true
        side-by-side = true
        syntax-theme = base16
[merge]
        conflictstyle = zdiff3
        tool = vimdiff
[mergetool]
        keepBackup = false
[help]
        autocorrect = prompt
[init]
        hints = false
        defaultBranch = main
